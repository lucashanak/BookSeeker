# BookSeeker admin credentials
ADMIN_USER=admin
ADMIN_PASS=changeme

# Prowlarr
PROWLARR_API_KEY=your-prowlarr-api-key

# Audiobookshelf credentials (for auto-login through proxy)
ABS_USER=admin
ABS_PASS=changeme

# Calibre-Web credentials (for auto-login through proxy)
CALIBRE_USER=admin
CALIBRE_PASS=changeme

# qBittorrent save paths (from qBittorrent's perspective)
QBIT_SAVE_PATH=/data/audiobooks
QBIT_EBOOK_SAVE_PATH=/data/ebooks

# Media directories (host paths)
AUDIOBOOK_DIR=./audiobooks
EBOOK_DIR=./ebooks

# Timezone
TZ=UTC

# BookSeeker port
PORT=8091
